# ============================================================
#  SWIFTPRINT — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ============================================================

# Server
PORT=3000
ALLOWED_ORIGIN=https://yourdomain.com

# SMTP Email (use Gmail App Password or any SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Business email that receives contact form submissions
CONTACT_EMAIL=hello@swiftprint.in
